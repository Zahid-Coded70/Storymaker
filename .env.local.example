# Copy this file to `.env.local` and fill in your key.
# Get one at: https://openrouter.ai/keys

OPENROUTER_API_KEY=

# Optional — defaults to openai/gpt-4o-mini if unset.
# Browse models: https://openrouter.ai/models
# Cheap defaults:
#   openai/gpt-4o-mini
#   google/gemini-2.0-flash-001
#   anthropic/claude-3.5-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional — shown on OpenRouter's request log
OPENROUTER_APP_NAME=Storymenia

# Optional — OpenRouter model used for per-page image generation.
# Must be a model that supports image output (returned as a base64 data URI).
# Browse: https://openrouter.ai/models?fmt=cards&output_modalities=image
# Default: google/gemini-2.5-flash-image
# Other options: google/gemini-3.1-flash-image-preview, openai/gpt-5-image-mini
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
